# ===== 이 파일을 복사해서 .env 로 만들고 값을 채우세요 =====
# cp .env.example .env
#
# ⚠️ 서버에 이미 다른 봇 토큰(TELEGRAM_BOT_TOKEN)이 있다면 그대로 두고,
#    이 프로그램(브리핑 봇 = 봇 1)은 아래 BRIEFING_ 변수만 새로 채우세요.
#    BRIEFING_ 값이 있으면 기존 TELEGRAM_ 값 대신 이걸 사용합니다(안 섞임).

# ----- 봇 1: 브리핑 봇 (이 프로그램이 자동 전송에 사용) -----
BRIEFING_BOT_TOKEN=여기에_새_브리핑봇_토큰A
BRIEFING_CHAT_ID=여기에_내_방번호

# (참고) 예전 방식 호환용 — BRIEFING_ 을 채웠다면 아래는 안 써도 됩니다.
# TELEGRAM_BOT_TOKEN=기존_토큰_그대로_둬도_됨
# TELEGRAM_CHAT_ID=기존_방번호

# ----- 한국투자증권 API -----
KIS_CANV_MODE=VIRTUAL          # 실전투자는 REAL, 모의투자는 VIRTUAL
KIS_APP_KEY=여기에_앱키
KIS_APP_SECRET=여기에_앱시크릿
KIS_ACCOUNT_NO=12345678-01     # 계좌번호

# ----- 웹 서버 (캡처는 이 주소의 화면을 찍습니다) -----
HOST=127.0.0.1
PORT=8000

# ----- 알람 검사 주기(분) -----
ALERT_CHECK_INTERVAL_MIN=10

# ----- (선택) 크롬 실행 파일 경로. 미설정 시 Playwright 기본값 -----
# CHROMIUM_PATH=/opt/pw-browsers/chromium

# ※ 봇 2(오픈클로 봇) 토큰은 여기에 넣지 마세요. 오픈클로 설정 화면에 넣습니다.
